{
	"name": "pi-free",
	"version": "1.0.9",
	"type": "module",
	"description": "Free AI models for Pi - Access free models from Zen, Kilo, OpenRouter, NVIDIA, Cline, Mistral, Ollama, Qwen, and Modal (plus Go and Fireworks as paid providers)",
	"keywords": [
		"pi-package",
		"pi-extension",
		"free-models",
		"ai-providers",
		"openrouter",
		"nvidia-nim",
		"kilo",
		"cline",
		"ollama",
		"mistral",
		"fireworks",
		"qwen",
		"qwen-oauth",
		"modal",
		"opencode-go",
		"zen"
	],
	"license": "MIT",
	"author": "Apostolos Mantzaris",
	"homepage": "https://github.com/apmantza/pi-free#readme",
	"bugs": {
		"url": "https://github.com/apmantza/pi-free/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/apmantza/pi-free.git"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"files": [
		"providers/**/*.ts",
		"lib/**/*.ts",
		"usage/**/*.ts",
		"provider-failover/**/*.ts",
		"widget/**/*.ts",
		"config.ts",
		"constants.ts",
		"provider-factory.ts",
		"provider-helper.ts",
		"README.md",
		"LICENSE",
		"CHANGELOG.md",
		"scripts/check-extensions.mjs"
	],
	"scripts": {
		"check": "node scripts/check-extensions.mjs",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run"
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"@vitest/ui": "^1.0.0",
		"tsx": "^4.0.0",
		"typescript": "^6.0.2",
		"vitest": "^1.0.0"
	},
	"pi": {
		"extensions": [
			"./providers/kilo.ts",
			"./providers/zen.ts",
			"./providers/go.ts",
			"./providers/openrouter.ts",
			"./providers/nvidia.ts",
			"./providers/cline.ts",
			"./providers/fireworks.ts",
			"./providers/mistral.ts",
			"./providers/ollama.ts",
			"./providers/qwen.ts",
			"./providers/modal.ts"
		]
	}
}
