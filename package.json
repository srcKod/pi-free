{
	"name": "pi-free",
	"version": "2.0.2",
	"type": "module",
	"description": "AI model providers for Pi with free model filtering. Shows only $0 cost models by default. Supports Kilo (free OAuth), Cline (free), NVIDIA (freemium), ZenMux, CrofAI, Ollama Cloud, and more.",
	"keywords": [
		"pi-package",
		"pi-extension",
		"free-models",
		"paid-models",
		"model-filter",
		"nvidia-nim",
		"kilo",
		"cline",
		"zenmux",
		"crofai",
		"ollama-cloud"
	],
	"license": "MIT",
	"author": "Apostolos Mantzaris",
	"homepage": "https://github.com/apmantza/pi-free#readme",
	"bugs": {
		"url": "https://github.com/apmantza/pi-free/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/apmantza/pi-free.git"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"files": [
		"index.ts",
		"providers/**/*.ts",
		"lib/**/*.ts",
		"provider-failover/**/*.ts",
		"config.ts",
		"constants.ts",
		"provider-helper.ts",
		"README.md",
		"LICENSE",
		"CHANGELOG.md",
		"scripts/check-extensions.mjs"
	],
	"scripts": {
		"check": "node scripts/check-extensions.mjs",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run"
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*"
	},
	"devDependencies": {
		"@vitest/ui": "^4.1.5",
		"tsx": "^4.0.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.5"
	},
	"pi": {
		"extensions": [
			"./index.ts"
		]
	}
}
