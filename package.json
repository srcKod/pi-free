{
	"name": "pi-free",
	"version": "1.0.9",
	"type": "module",
	"description": "Free model filtering for Pi - Adds free/paid filtering for ALL providers (built-in + extension). Includes unique providers: Kilo, NVIDIA, Cline, Qwen, Modal, Fireworks.",
	"keywords": [
		"pi-package",
		"pi-extension",
		"free-models",
		"model-filter",
		"nvidia-nim",
		"kilo",
		"cline",
		"fireworks",
		"qwen",
		"qwen-oauth",
		"modal"
	],
	"license": "MIT",
	"author": "Apostolos Mantzaris",
	"homepage": "https://github.com/apmantza/pi-free#readme",
	"bugs": {
		"url": "https://github.com/apmantza/pi-free/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/apmantza/pi-free.git"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"files": [
		"index.ts",
		"providers/**/*.ts",
		"lib/**/*.ts",
		"provider-failover/**/*.ts",
		"config.ts",
		"constants.ts",
		"provider-factory.ts",
		"provider-helper.ts",
		"README.md",
		"LICENSE",
		"CHANGELOG.md",
		"scripts/check-extensions.mjs"
	],
	"scripts": {
		"check": "node scripts/check-extensions.mjs",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run"
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"@vitest/ui": "^1.0.0",
		"tsx": "^4.0.0",
		"typescript": "^6.0.2",
		"vitest": "^1.0.0"
	},
	"pi": {
		"extensions": [
			"./index.ts"
		]
	}
}
